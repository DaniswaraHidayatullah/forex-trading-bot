# Salin ke .env untuk dev lokal. JANGAN commit .env yang asli.

# Berapa lama (detik) cache berita/COT dianggap masih segar
CACHE_TTL_SECONDS=1800

# Menit sebelum & sesudah event high-impact untuk blokir entry
NEWS_BLACKOUT_MINUTES=30

# Impact minimal yang dianggap "berbahaya": low | medium | high
NEWS_MIN_IMPACT=high

# Token sederhana untuk proteksi endpoint (opsional, dicek di header X-Api-Key)
API_TOKEN=

# --- Sentimen berita ---------------------------------------------------
# Aktif/nonaktifkan modul scraping sentimen
SENTIMENT_ENABLED=true

# Backend skoring: lexicon (gratis, default) | llm (butuh ANTHROPIC_API_KEY +
# `pip install anthropic`; otomatis fallback ke lexicon kalau tak tersedia)
SENTIMENT_BACKEND=lexicon
# ANTHROPIC_API_KEY=   # hanya diisi kalau SENTIMENT_BACKEND=llm

# --- Signal engine (sinyal /signal untuk eksekusi manual) --------------
# API key Twelve Data (GRATIS, tanpa kartu) dari https://twelvedata.com
# Tanpa key, /signal balas "API key belum diset".
TWELVEDATA_API_KEY=

# Ambang |skor| (0..1) sebelum dianggap punya arah (long/short)
SENTIMENT_THRESHOLD=0.15

# Minimal jumlah headline relevan agar tidak otomatis "flat"
SENTIMENT_MIN_HEADLINES=3

# Cache khusus berita (detik) -- berita cepat basi, jadi lebih pendek
SENTIMENT_CACHE_TTL_SECONDS=900

# Override daftar feed RSS (pisahkan dengan koma). Kosongkan utk pakai default.
# SENTIMENT_FEEDS=https://www.forexlive.com/feed/news,https://www.fxstreet.com/rss/news
