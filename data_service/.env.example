# Salin ke .env untuk dev lokal. JANGAN commit .env yang asli.

# Berapa lama (detik) cache berita/COT dianggap masih segar
CACHE_TTL_SECONDS=1800

# Menit sebelum & sesudah event high-impact untuk blokir entry
NEWS_BLACKOUT_MINUTES=30

# Impact minimal yang dianggap "berbahaya": low | medium | high
NEWS_MIN_IMPACT=high

# Token sederhana untuk proteksi endpoint (opsional, dicek di header X-Api-Key)
API_TOKEN=

# --- Sentimen berita ---------------------------------------------------
# Aktif/nonaktifkan modul scraping sentimen
SENTIMENT_ENABLED=true

# Backend skoring: lexicon (gratis, default) | llm | finbert
#  - llm     : butuh ANTHROPIC_API_KEY + `pip install anthropic`
#  - finbert : pakai Hugging Face Inference API (butuh HF_API_TOKEN gratis),
#              hanya menilai headline tentang emas. RAM ringan (model di HF).
# Semua otomatis fallback ke lexicon kalau token/paket tak tersedia.
SENTIMENT_BACKEND=lexicon
# ANTHROPIC_API_KEY=   # hanya kalau SENTIMENT_BACKEND=llm
# HF_API_TOKEN=        # hanya kalau SENTIMENT_BACKEND=finbert (huggingface.co -> Settings -> Tokens)

# --- Signal engine (sinyal /signal untuk eksekusi manual) --------------
# API key Twelve Data (GRATIS, tanpa kartu) dari https://twelvedata.com
# Tanpa key, /signal balas "API key belum diset".
TWELVEDATA_API_KEY=

# Discord: pilih SALAH SATU cara kirim.
# Cara A - Webhook (paling gampang): Server Settings -> Integrations ->
#   Webhooks -> New Webhook -> Copy URL.
DISCORD_WEBHOOK_URL=
# Cara B - Bot (pakai nama/avatar bot-mu). Isi DUA-DUANYA:
#   Token: Developer Portal -> aplikasi bot -> Bot -> Reset/Copy Token
#   Channel ID: aktifkan Developer Mode di Discord -> klik kanan channel ->
#   Copy Channel ID. Bot harus sudah di-invite & punya izin kirim pesan.
# Kalau bot diisi, itu yang dipakai (mengalahkan webhook).
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# Auto kirim ke Discord saat ada sinyal (true/false)
SIGNAL_AUTO_PUSH=true
# Cek sinyal tiap N detik (default 1800 = 30 menit, samai bar M30)
SIGNAL_POLL_SECONDS=1800
# Profil yang di-auto-push ke Discord (pisah koma): scalp, intraday, swing
SIGNAL_PROFILES=intraday
# Minimal keyakinan untuk auto-push: none | medium | strong
# medium (default) = sinyal teknikal-only TANPA dukungan sentimen tidak dikirim
SIGNAL_MIN_CONFIDENCE=medium
# Batas risiko $ per trade @0.01 lot; sinyal dgn jarak SL lebih besar di-skip
SIGNAL_MAX_RISK_USD=12

# Ambang |skor| (0..1) sebelum dianggap punya arah (long/short)
SENTIMENT_THRESHOLD=0.15

# Minimal jumlah headline relevan agar tidak otomatis "flat"
SENTIMENT_MIN_HEADLINES=3

# Cache khusus berita (detik) -- berita cepat basi, jadi lebih pendek
SENTIMENT_CACHE_TTL_SECONDS=900

# Override daftar feed RSS (pisahkan dengan koma). Kosongkan utk pakai default.
# SENTIMENT_FEEDS=https://www.forexlive.com/feed/news,https://www.fxstreet.com/rss/news
